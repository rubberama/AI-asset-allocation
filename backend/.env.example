# OpenRouter API Configuration
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Database Settings
DATABASE_URL=sqlite:///nps_platform.db

# Risk-Free Rate Default (fallback if ^TNX download fails)
DEFAULT_RISK_FREE_RATE=0.035

# Risk Aversion Parameter (lambda)
DEFAULT_RISK_AVERSION=2.5

# Black-Litterman Scaling Factor (tau)
DEFAULT_TAU=0.05

# Marketaux News API (market intelligence source)
MARKETAUX_API_KEY=your_marketaux_api_key_here
MARKETAUX_LIMIT=3
MARKETAUX_INDUSTRIES=Financial Services,Technology

# READING tasks: article-to-thesis extraction, headline selection (long-context, fast)
ARTICLE_DIGESTION_MODEL=openrouter/owl-alpha
OPENROUTER_MODEL=openrouter/owl-alpha

# REASONING tasks: view parsing, PM memo, variance calibration, AI commentary, thesis consolidation
# Nemotron 3 Ultra 550B (MoE) — NVIDIA June 2026 frontier reasoning model, free on OpenRouter
VIEW_PARSING_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
REASONING_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# FRED (Federal Reserve Economic Data) free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=your_fred_api_key_here
